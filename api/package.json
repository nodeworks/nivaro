{
  "name": "@nivaro/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "build:ci": "tsc -p tsconfig.build.json || true && tsc-alias -p tsconfig.build.json",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:rollback": "tsx src/db/migrate.ts rollback",
    "fix:roles": "tsx src/db/fix-roles.ts",
    "fix:collections": "tsx src/db/fix-collections.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.101.0",
    "@aws-sdk/client-s3": "^3.1064.0",
    "@azure/storage-blob": "^12.32.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/session": "^11.0.1",
    "@fastify/static": "^9.1.3",
    "@node-saml/node-saml": "^5.1.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "croner": "^10.0.1",
    "dotenv": "^17.4.2",
    "expr-eval": "^2.0.2",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "graphql": "^16.14.1",
    "graphql-ws": "^6.0.8",
    "inngest": "^3.32.0",
    "ioredis": "^5.4.2",
    "js-yaml": "^4.2.0",
    "knex": "^3.1.0",
    "liquidjs": "^10.21.0",
    "mime-types": "^2.1.35",
    "nodemailer": "^8.0.10",
    "openid-client": "^6.5.0",
    "otplib": "^13.4.1",
    "pdfkit": "^0.19.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "tedious": "^19.0.0",
    "ulid": "^2.3.0",
    "ws": "^8.18.2",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.15.21",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.0",
    "supertest": "^7.0.0",
    "tsc-alias": "^1.8.17",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^2.1.0"
  }
}
