<!doctype html>
<html lang="en">
<head>
  <title>Nivaro</title>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="x-apple-disable-message-reformatting">
  <style type="text/css">
    body,table,td,a{-webkit-text-size-adjust:100%;-ms-text-size-adjust:100%;-webkit-font-smoothing:antialiased;}
    table,td{mso-table-lspace:0pt;mso-table-rspace:0pt;}
    img{-ms-interpolation-mode:bicubic;border:0;height:auto;line-height:100%;outline:none;text-decoration:none;}
    table{border-collapse:collapse!important;}
    body{height:100%!important;margin:0!important;padding:0!important;width:100%!important;}
    a[x-apple-data-detectors]{color:inherit!important;text-decoration:none!important;font-size:inherit!important;font-family:inherit!important;font-weight:inherit!important;line-height:inherit!important;}
    div[style*="margin: 16px 0;"]{margin:0!important;}
    @media screen and (max-width:620px){
      .card-wrap{width:100%!important;}
      .card-pad{padding:28px 22px!important;}
      .hdr-pad{padding:16px 22px!important;}
      .ftr-pad{padding:18px 22px!important;}
      .stat-col{display:block!important;width:100%!important;border-right:none!important;border-bottom:1px solid #dde3ea!important;}
    }
    @media (prefers-color-scheme:dark){
      body,#page-bg{background-color:#0d1a27!important;}
      #card{background-color:#1b2c3e!important;}
      #card-hdr{background-color:#0f1f2f!important;border-bottom-color:#1e3347!important;}
      #card-body{background-color:#1b2c3e!important;color:#dde6f0!important;}
      #card-ftr{background-color:#0f1f2f!important;border-top-color:#1e3347!important;}
      .ftr-text{color:#6b849e!important;}
      .field-label-cell{background-color:#0f1f2f!important;border-color:#1e3347!important;}
      .field-value-cell{background-color:#1b2c3e!important;border-color:#1e3347!important;color:#dde6f0!important;}
      .field-label-txt{color:#6b849e!important;}
      .field-value-txt{color:#dde6f0!important;}
      .field-sub-txt{color:#4a6a86!important;}
      .stat-card{background-color:#0f1f2f!important;border-color:#1e3347!important;}
      .stat-value{color:#dde6f0!important;}
      .note-block{background-color:#0c1e30!important;border-color:#1e3347!important;}
      .note-txt{color:#c5d4e8!important;}
      .note-meta{color:#4a6a86!important;}
      .section-hdr{background-color:#172940!important;border-color:#1e3347!important;}
      .body-txt{color:#9ab0c8!important;}
      .badge-txt{color:#0a9ec0!important;background-color:#0a2335!important;}
    }
  </style>
</head>
<body style="margin:0;padding:0;background-color:#172940;" bgcolor="#172940">

<div style="display:none;font-size:1px;color:#172940;line-height:1px;max-height:0;max-width:0;opacity:0;overflow:hidden;">Nivaro&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;</div>

<table id="page-bg" role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" bgcolor="#172940" style="background-color:#172940;">
  <tr>
    <td align="center" valign="top" style="padding:36px 16px 52px;">

      <!--[if (gte mso 9)|(IE)]><table align="center" border="0" cellspacing="0" cellpadding="0" width="580"><tr><td width="580"><![endif]-->
      <table id="card" class="card-wrap" role="presentation" border="0" cellpadding="0" cellspacing="0" style="max-width:580px;width:100%;background-color:#ffffff;border-radius:12px;overflow:hidden;" bgcolor="#ffffff">

        <!-- ─── Cyan top rule ─── -->
        <tr>
          <td height="4" bgcolor="#00ceff" style="background-color:#00ceff;font-size:0;line-height:0;mso-line-height-rule:exactly;">&nbsp;</td>
        </tr>

        <!-- ─── Header zone ─── -->
        <tr>
          <td id="card-hdr" class="hdr-pad" style="background-color:#eef6fb;border-bottom:1px solid #d4e9f5;padding:18px 36px;" bgcolor="#eef6fb">
            <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
              <tr>
                <td valign="middle">
                  <span style="font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:700;color:#172940;letter-spacing:0.2px;">Nivaro</span>
                </td>
                <td align="right" valign="middle">
                  <span style="font-family:Arial,Helvetica,sans-serif;font-size:10px;font-weight:700;color:#94afc4;text-transform:uppercase;letter-spacing:1px;">Nivaro</span>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- ─── Body content ─── -->
        <tr>
          <td id="card-body" class="card-pad" style="background-color:#ffffff;padding:40px 36px;font-family:Open Sans,Helvetica,Arial,sans-serif;font-size:15px;line-height:26px;color:#1e293b;" bgcolor="#ffffff">
            {% block content %}{{ html }}{% endblock %}
          </td>
        </tr>

        <!-- ─── Footer ─── -->
        <tr>
          <td id="card-ftr" class="ftr-pad" style="background-color:#f4f7fa;border-top:1px solid #dde3ea;padding:18px 36px;" bgcolor="#f4f7fa">
            <p class="ftr-text" style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#7a90a6;line-height:20px;">
              Sent by <strong style="color:#4a6880;">Nivaro</strong> &mdash; This is an automated notification. Please do not reply to this email.{% block footer %}{% endblock %}
            </p>
          </td>
        </tr>

      </table>
      <!--[if (gte mso 9)|(IE)]></td></tr></table><![endif]-->

    </td>
  </tr>
</table>

</body>
</html>
