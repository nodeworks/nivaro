# ─── API ────────────────────────────────────────────────────────────────────
PORT=3055
NODE_ENV=development
LOG_LEVEL=info
PUBLIC_URL=http://localhost:3055

# ─── Database (MSSQL) ────────────────────────────────────────────────────────
DB_HOST=your-db-host.example.com
DB_PORT=1433
DB_DATABASE=your_database
DB_USER=sa
DB_PASSWORD=your_password
DB_ENCRYPT=false
DB_TRUST_SERVER_CERT=true

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Session ─────────────────────────────────────────────────────────────────
# Must be at least 32 characters
SESSION_SECRET=change_this_to_a_long_random_string_minimum_32_chars
SESSION_TTL=86400
# Set to true only when serving over HTTPS (false for local dev and plain-HTTP Docker)
COOKIE_SECURE=false

# ─── Microsoft OAuth2 / OIDC ─────────────────────────────────────────────────
OIDC_ISSUER=https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0
OIDC_CLIENT_ID=your_azure_app_client_id
OIDC_CLIENT_SECRET=your_azure_app_client_secret
OIDC_REDIRECT_URI=http://localhost:3055/api/auth/callback

# ─── Admin UI ────────────────────────────────────────────────────────────────
# Where to redirect after login
ADMIN_URL=http://localhost:3056

# ─── Inngest ─────────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=local

# ─── Mail (SMTP) ─────────────────────────────────────────────────────────────
MAIL_FROM=Nivaro <no-reply@example.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# ─── File Storage ────────────────────────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./uploads
