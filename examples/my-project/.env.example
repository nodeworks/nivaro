# ─── Database ────────────────────────────────────────────────────────────────
# Database client: mssql (default) | pg | mysql2.
# pg / mysql2 drivers are optional — install the npm package when used.
# DB_CLIENT=mssql
DB_HOST=your-db-host.example.com
# Optional — defaults per client: mssql 1433, pg 5432, mysql2 3306
# DB_PORT=
DB_DATABASE=your_database
DB_USER=sa
DB_PASSWORD=your_password
DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=true
# Required for the MSSQL tedious driver when connecting to servers with self-signed
# or internal CA certs. Remove if your DB server has a publicly-trusted certificate.
NODE_TLS_REJECT_UNAUTHORIZED=0

# Read replica (optional) — when DB_READ_HOST is set, GET-heavy queries can be
# routed to the replica. DB_READ_PORT falls back to DB_PORT / client default.
# DB_READ_HOST=
# DB_READ_PORT=

# Zero-downtime migrations (optional) — advisory lock prevents concurrent
# migration runs across instances during rolling deploys.
# MIGRATION_SAFE_MODE=true
# MIGRATION_LOCK_TIMEOUT_MS=60000

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_string_minimum_32_chars
SESSION_TTL=86400
# Set to false for plain HTTP (Docker default). true only when Fastify receives HTTPS directly.
COOKIE_SECURE=false

# ─── Microsoft OAuth2 / OIDC ─────────────────────────────────────────────────
OIDC_ISSUER=https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0
OIDC_CLIENT_ID=your_azure_app_client_id
OIDC_CLIENT_SECRET=your_azure_app_client_secret
OIDC_REDIRECT_URI=http://localhost:3055/api/auth/callback

# ─── URLs ────────────────────────────────────────────────────────────────────
PUBLIC_URL=http://localhost:3055
ADMIN_URL=http://localhost:3055

# ─── Redis ───────────────────────────────────────────────────────────────────
# Overridden to redis://redis:6379 inside Docker Compose
REDIS_URL=redis://localhost:6379

# ─── Inngest ─────────────────────────────────────────────────────────────────
# Local dev: use the literal string "local" (bypasses cloud auth)
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=local
# Docker: must be a real 64-char hex key. Set in your shell or CI secrets.
# The compose file falls back to a dev placeholder if this is unset.
INNGEST_SIGNING_KEY_DOCKER=

# ─── AI Features (optional) ──────────────────────────────────────────────────
# Used by POST /api/ai/generate and /api/ai/summarize (admin only).
# Can also be configured via Settings > AI Features in the admin UI.
ANTHROPIC_API_KEY=

# ─── Mail (SMTP) — optional ──────────────────────────────────────────────────
MAIL_FROM=Nivaro <no-reply@example.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
