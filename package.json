{
  "name": "nivaro-cms",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n redis,inngest,api,admin -c cyan,magenta,blue,green \"pnpm dev:redis\" \"wait-on tcp:6379 && pnpm dev:inngest\" \"wait-on tcp:6379 && pnpm dev:api\" \"pnpm --filter @nivaro/admin dev\"",
    "dev:api": "pnpm --filter @nivaro/api dev",
    "dev:admin": "pnpm --filter @nivaro/admin dev",
    "dev:redis": "docker run --rm -p 6379:6379 redis:7-alpine",
    "dev:inngest": "npx inngest-cli@latest dev -u http://localhost:3055/api/inngest",
    "dev:docker": "docker compose up --build",
    "dev:docker:down": "docker compose down",
    "dev:www": "npx browser-sync start --server www --files 'www/**/*' --port 3057 --open --extensions html",
    "build": "pnpm --filter @nivaro/api build && pnpm --filter @nivaro/admin build",
    "release": "./api/node_modules/.bin/tsx scripts/sync-docs.ts && node scripts/release.mjs",
    "sdk:release": "./api/node_modules/.bin/tsx scripts/sync-docs.ts && node scripts/release-sdk.mjs",
    "www:release": "./api/node_modules/.bin/tsx scripts/sync-docs.ts && node scripts/release-www.mjs",
    "sync-docs": "./api/node_modules/.bin/tsx scripts/sync-docs.ts",
    "docs:api": "node scripts/generate-api-docs.mjs",
    "migrate": "pnpm --filter @nivaro/api migrate",
    "migrate:rollback": "pnpm --filter @nivaro/api migrate:rollback",
    "seed:directus": "pnpm --filter @nivaro/api seed:directus",
    "fix:roles": "pnpm --filter @nivaro/api fix:roles",
    "fix:collections": "pnpm --filter @nivaro/api fix:collections",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "dead-code": "fallow dead-code",
    "dupes": "fallow dupes",
    "health": "fallow health",
    "test:api": "pnpm --filter @nivaro/api test",
    "test:admin": "pnpm --filter @nivaro/admin test",
    "test:unit": "pnpm --filter @nivaro/api test && pnpm --filter @nivaro/admin test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed --channel chrome",
    "test:e2e:cdp": "playwright test --config playwright.cdp.config.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.101.0",
    "@axe-core/playwright": "^4.10.0",
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.49.0",
    "concurrently": "^9.1.2",
    "fallow": "^2.88.3",
    "wait-on": "^9.0.10"
  }
}
